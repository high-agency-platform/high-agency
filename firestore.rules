rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model (v1.1 — squad cohorts, milestone track, build logs)
    // ===============================================================
    //
    // Collection: applications (legacy public waitlist)
    //   Create-only from the waitlist form; never readable (minor PII).
    //
    // Document: meta/waitlist — public counter only.
    //
    // Collection: profiles/{uid} — the operator profile. Readable by any
    //   signed-in user (it IS the cohort application artifact). Privacy
    //   by construction: name is "First L.", age is a band, location is
    //   country + timezone. No email/phone/DOB/exact city ever.
    //   role ('operator'|'mentor') and plan ('free'|'pro') are set by
    //   admin tooling (OAuth bypasses rules) or, for mentors, by the
    //   invite-redemption Route Handler (Admin SDK — /api/mentor/redeem);
    //   clients can't grant themselves either. Other users may bump xp only (bounded) —
    //   this is how verifiers pay out milestone XP (client-trusted v1).
    //
    // Collection: privateProfiles/{uid} — DOB, full name, exact city,
    //   parent email. Owner-only, both directions. Never listed.
    //
    // Collection: cohorts/{id} — accountability squads (3–8 operators).
    //   Founder manages the doc; any member may update only the weekly
    //   ritual streak fields. peerLead verifies milestones 1–3.
    //   Subcollections:
    //     applications/{applicantUid} — pitch + status + declineReason
    //     submissions/{milestoneId_uid} — per-operator milestone evidence
    //     logs/{auto} — build log entries (the squad's pulse)
    //
    // Collection: workshops — staff-seeded; read-only for clients.
    //
    // ===============================================================
    // Helpers
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function validString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    // Rules can't loop over list elements; we bound count + rely on
    // small max sizes to cap damage (residual risk accepted for v1).
    function validStringList(value, maxItems) {
      return value is list && value.size() <= maxItems;
    }

    function cohortData(cohortId) {
      return get(/databases/$(database)/documents/cohorts/$(cohortId)).data;
    }

    function isCohortMember(cohortId) {
      return isAuthenticated() && request.auth.uid in cohortData(cohortId).memberUids;
    }

    function isCohortFounder(cohortId) {
      return isAuthenticated() && request.auth.uid == cohortData(cohortId).founderUid;
    }

    function isCohortPeerLead(cohortId) {
      return isAuthenticated() && request.auth.uid == cohortData(cohortId).peerLeadUid;
    }

    function isMentor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'mentor';
    }

    // Parental-consent gate for community writes. A minor whose parent hasn't
    // approved yet has consentStatus == 'pending' and is blocked from all
    // community writes (cohorts, applications, submissions, logs, rituals).
    // Missing profile / missing field (legacy or adult) reads as allowed —
    // only an explicit 'pending' blocks. Grants are server- or mentor-driven,
    // never a self-write (consentStatus is immutable on the owner update path).
    function consentAllows(uid) {
      return !exists(/databases/$(database)/documents/profiles/$(uid)) ||
        get(/databases/$(database)/documents/profiles/$(uid)).data.get('consentStatus', 'granted') != 'pending';
    }

    // ===============================================================
    // Legacy waitlist (unchanged: create-only, PII never readable)
    // ===============================================================

    match /applications/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'age', 'building', 'boldest']) &&
                       validString(request.resource.data.name, 1, 120) &&
                       validString(request.resource.data.email, 3, 254) &&
                       validString(request.resource.data.building, 0, 2000) &&
                       validString(request.resource.data.boldest, 0, 2000);
      allow read, update, delete: if false;
    }

    match /meta/waitlist {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['count', 'updatedAt']) &&
                      request.resource.data.count is number &&
                      request.resource.data.count >= 0 &&
                      request.resource.data.count < 1000000;
    }

    // ===============================================================
    // Profiles
    // ===============================================================

    function isValidProfile(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'ageBand', 'country', 'timezone',
               'headline', 'building', 'stage', 'domains', 'skills',
               'proofUrl', 'proofNote', 'hours', 'bio', 'links',
               'consentStatus', 'consentEmailSentAt', 'plan', 'role',
               'xp', 'streak', 'streakFreezes', 'lastActiveDay',
               'lastBuildLogDay', 'lastRitualWeek',
               'enrolledWorkshops', 'attendedWorkshops', 'pendingApplications',
               'createdAt', 'updatedAt']) &&
             hasRequiredFields(['uid', 'name', 'ageBand', 'country', 'timezone',
               'headline', 'building', 'stage', 'domains', 'skills',
               'consentStatus', 'plan', 'role',
               'xp', 'streak', 'streakFreezes', 'lastActiveDay',
               'pendingApplications', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             validString(data.name, 1, 80) &&
             data.ageBand in ['13-15', '16-17', '18+'] &&
             validString(data.country, 1, 60) &&
             validString(data.timezone, 1, 60) &&
             validString(data.headline, 0, 90) &&
             validString(data.building, 0, 300) &&
             data.stage in ['idea', 'building', 'launched', 'revenue'] &&
             validStringList(data.domains, 9) && data.domains.size() >= 1 &&
             validStringList(data.skills, 7) && data.skills.size() >= 1 &&
             (!('proofUrl' in data) || validString(data.proofUrl, 0, 300)) &&
             (!('proofNote' in data) || validString(data.proofNote, 0, 200)) &&
             // Weekly hours moved to per-application; kept optional here so
             // legacy profile docs that still carry it continue to validate.
             (!('hours' in data) || data.hours in ['<3', '3-5', '5-10', '10+']) &&
             (!('bio' in data) || validString(data.bio, 0, 300)) &&
             (!('links' in data) || (data.links is map && data.links.keys().hasOnly(['github', 'linkedin', 'site']))) &&
             data.consentStatus in ['none', 'pending', 'granted'] &&
             (!('consentEmailSentAt' in data) || data.consentEmailSentAt is timestamp) &&
             data.plan in ['free', 'pro'] &&
             data.role in ['operator', 'mentor'] &&
             data.xp is number && data.xp >= 0 && data.xp <= 10000000 &&
             data.streak is number && data.streak >= 0 && data.streak <= 100000 &&
             data.streakFreezes is number && data.streakFreezes >= 0 && data.streakFreezes <= 3 &&
             validString(data.lastActiveDay, 10, 10) &&
             (!('lastBuildLogDay' in data) || validString(data.lastBuildLogDay, 0, 10)) &&
             (!('lastRitualWeek' in data) || validString(data.lastRitualWeek, 0, 8)) &&
             (!('enrolledWorkshops' in data) || validStringList(data.enrolledWorkshops, 100)) &&
             (!('attendedWorkshops' in data) || validStringList(data.attendedWorkshops, 100)) &&
             validStringList(data.pendingApplications, 3);
    }

    // Verifiers pay milestone XP into other operators' profiles: the
    // only cross-user write allowed is a bounded xp increase.
    function isXpAward() {
      return isAuthenticated() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'updatedAt']) &&
             request.resource.data.xp is number &&
             request.resource.data.xp > resource.data.xp &&
             request.resource.data.xp <= resource.data.xp + 300;
    }

    // Mentors (trusted staff) grant parental consent in-app — the only
    // other cross-user profile write. Scoped to flipping consentStatus to
    // 'granted'; role and plan grants stay server-side (admin CLI tooling
    // and the mentor-invite redemption route).
    function isConsentGrant() {
      return isMentor() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['consentStatus', 'updatedAt']) &&
             request.resource.data.consentStatus == 'granted';
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      // Clients always start as free-tier operators; admin tooling
      // (which bypasses rules) grants mentor role / pro plan.
      allow create: if isOwner(userId) && isValidProfile(request.resource.data) &&
                       request.resource.data.role == 'operator' &&
                       request.resource.data.plan == 'free';
      // consentStatus + consentEmailSentAt are immutable on a self-update: a
      // pending minor must NOT be able to grant their own consent. Consent is
      // flipped only by a mentor (isConsentGrant) or the server (Admin SDK,
      // which bypasses rules) via the parent-approval link.
      allow update: if (isOwner(userId) && isValidProfile(request.resource.data) &&
                        areImmutableFieldsUnchanged(['uid', 'createdAt', 'role', 'plan',
                          'consentStatus', 'consentEmailSentAt'])) ||
                       isXpAward() ||
                       isConsentGrant();
      allow delete: if false;
    }

    // ===============================================================
    // Private profiles — owner-only, both directions
    // ===============================================================

    match /privateProfiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        hasOnlyAllowedFields(['uid', 'firstName', 'lastName', 'dob', 'city', 'parentEmail', 'createdAt', 'updatedAt']) &&
        request.resource.data.uid == request.auth.uid &&
        validString(request.resource.data.firstName, 1, 60) &&
        validString(request.resource.data.lastName, 1, 60) &&
        validString(request.resource.data.dob, 10, 10) &&
        (!('city' in request.resource.data) || validString(request.resource.data.city, 0, 80)) &&
        (!('parentEmail' in request.resource.data) || validString(request.resource.data.parentEmail, 0, 254));
      allow delete: if false;
    }

    // ===============================================================
    // Cohorts
    // ===============================================================

    function isValidCohort(data) {
      return hasOnlyAllowedFields(['name', 'mission', 'tags', 'lookingFor', 'meetingSlot',
               'link', 'icon', 'timezone', 'state', 'founderUid', 'founderName', 'peerLeadUid',
               'memberUids', 'memberNames', 'open', 'weeklyStreak', 'lastRitualWeek', 'createdAt']) &&
             hasRequiredFields(['name', 'mission', 'meetingSlot', 'timezone', 'state',
               'founderUid', 'founderName', 'peerLeadUid',
               'memberUids', 'memberNames', 'open', 'weeklyStreak', 'createdAt']) &&
             validString(data.name, 1, 60) &&
             validString(data.mission, 1, 140) &&
             // Focus tags may be preset domains or founder-typed free text.
             // Count is bounded here (mirrors MAX_FOCUS_TAGS in the client);
             // per-tag length/content is normalized client-side since rules
             // can't loop a list. Residual free-text risk accepted for v1.
             (!('tags' in data) || validStringList(data.tags, 6)) &&
             (!('lookingFor' in data) || validStringList(data.lookingFor, 7)) &&
             validString(data.meetingSlot, 1, 80) &&
             // Optional landing page: blank, or an http(s) URL under 200 chars.
             (!('link' in data) ||
               (data.link is string && data.link.size() <= 200 &&
                (data.link == '' || data.link.matches('https?://.*')))) &&
             // Optional icon: blank, or an inline data:image URL. Bounded to
             // mirror COHORT_ICON_MAX_CHARS — keeps list reads lean and the doc
             // under 1MB. It's a data URL, so nothing external loads for viewers.
             (!('icon' in data) ||
               (data.icon is string && data.icon.size() <= 40000 &&
                (data.icon == '' || data.icon.matches('data:image/.*')))) &&
             validString(data.timezone, 1, 60) &&
             data.state in ['forming', 'active', 'stalled', 'archived'] &&
             data.founderUid is string &&
             validString(data.founderName, 1, 80) &&
             data.peerLeadUid is string &&
             validStringList(data.memberUids, 8) && data.memberUids.size() >= 1 &&
             data.memberNames is map && data.memberNames.size() <= 8 &&
             data.open is bool &&
             data.weeklyStreak is number && data.weeklyStreak >= 0 && data.weeklyStreak <= 1000 &&
             (!('lastRitualWeek' in data) || validString(data.lastRitualWeek, 0, 8));
    }

    // Any member may log the weekly ritual — only those two fields.
    function isRitualUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weeklyStreak', 'lastRitualWeek']) &&
             request.resource.data.weeklyStreak is number &&
             request.resource.data.weeklyStreak >= 0 &&
             request.resource.data.weeklyStreak <= resource.data.weeklyStreak + 1 &&
             validString(request.resource.data.lastRitualWeek, 0, 8);
    }

    match /cohorts/{cohortId} {
      allow read: if isAuthenticated();

      // Creator must be founder, peer-lead, and sole initial member;
      // new cohorts start forming with no streak.
      allow create: if isAuthenticated() &&
                       consentAllows(request.auth.uid) &&
                       isValidCohort(request.resource.data) &&
                       request.resource.data.founderUid == request.auth.uid &&
                       request.resource.data.peerLeadUid == request.auth.uid &&
                       request.resource.data.memberUids == [request.auth.uid] &&
                       request.resource.data.state == 'forming' &&
                       request.resource.data.weeklyStreak == 0;

      // Founder manages the doc; founder must stay a member and the
      // peer-lead must be a member. Members may only tick the ritual.
      allow update: if consentAllows(request.auth.uid) &&
                       ((isCohortFounder(cohortId) &&
                        isValidCohort(request.resource.data) &&
                        areImmutableFieldsUnchanged(['founderUid', 'founderName', 'createdAt']) &&
                        request.resource.data.founderUid in request.resource.data.memberUids &&
                        request.resource.data.peerLeadUid in request.resource.data.memberUids) ||
                       (isCohortMember(cohortId) && isRitualUpdate()));

      allow delete: if false;

      // ---------------- Applications ----------------

      function isValidApplication(data) {
        return hasOnlyAllowedFields(['applicantUid', 'applicantName', 'pitch', 'hours', 'status', 'declineReason', 'createdAt']) &&
               hasRequiredFields(['applicantUid', 'applicantName', 'pitch', 'hours', 'status', 'createdAt']) &&
               validString(data.applicantName, 1, 80) &&
               validString(data.pitch, 0, 300) &&
               data.hours in ['<3', '3-5', '5-10', '10+'];
      }

      match /applications/{applicantId} {
        allow read: if isOwner(applicantId) || isCohortMember(cohortId);

        // Apply as yourself, always starting pending; members can't
        // apply to their own cohort.
        allow create: if isOwner(applicantId) &&
                         consentAllows(request.auth.uid) &&
                         isValidApplication(request.resource.data) &&
                         request.resource.data.applicantUid == applicantId &&
                         request.resource.data.status == 'pending' &&
                         request.resource.data.declineReason == null &&
                         !(request.auth.uid in cohortData(cohortId).memberUids);

        // Only the founder decides, only from pending. Declines need a
        // one-tap reason; accepts must add the applicant to the roster
        // in the same batch (getAfter checks the parent cohort).
        allow update: if isCohortFounder(cohortId) &&
                         resource.data.status == 'pending' &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'declineReason']) &&
                         request.resource.data.status in ['accepted', 'declined'] &&
                         ((request.resource.data.status == 'declined' &&
                           request.resource.data.declineReason in ['full', 'different_focus', 'timezone']) ||
                          (request.resource.data.status == 'accepted' &&
                           request.resource.data.declineReason == null &&
                           applicantId in getAfter(/databases/$(database)/documents/cohorts/$(cohortId)).data.memberUids));

        // Applicants may withdraw while pending.
        allow delete: if isOwner(applicantId) && resource.data.status == 'pending';
      }

      // ---------------- Milestone submissions ----------------
      // Doc id is `${milestoneId}_${uid}` — one per operator per
      // milestone; resubmits overwrite in place.

      function isValidSubmission(data) {
        return hasOnlyAllowedFields(['uid', 'name', 'milestoneId', 'evidenceUrl', 'note',
                 'status', 'verifierUid', 'verifierName', 'returnReason', 'createdAt', 'decidedAt']) &&
               hasRequiredFields(['uid', 'name', 'milestoneId', 'evidenceUrl', 'status']) &&
               validString(data.name, 1, 80) &&
               data.milestoneId is number && data.milestoneId >= 1 && data.milestoneId <= 7 &&
               validString(data.evidenceUrl, 1, 500) &&
               (!('note' in data) || validString(data.note, 0, 500));
      }

      // Tiered verification: 1–3 peer-lead (mentor can spot-check),
      // 4–7 mentor-only — those gate levels and go on the record.
      function canVerify(milestoneId) {
        return (milestoneId <= 3 && (isCohortPeerLead(cohortId) || isMentor())) ||
               (milestoneId >= 4 && isMentor());
      }

      match /submissions/{subId} {
        // Mentors can read without membership (they verify across squads).
        allow read: if isCohortMember(cohortId) || isMentor();

        allow create: if isCohortMember(cohortId) &&
                         consentAllows(request.auth.uid) &&
                         isValidSubmission(request.resource.data) &&
                         request.resource.data.uid == request.auth.uid &&
                         subId == string(request.resource.data.milestoneId) + '_' + request.auth.uid &&
                         request.resource.data.status == 'submitted';

        // Owner resubmits after a return; verifier decides submitted work.
        allow update: if (isOwner(resource.data.uid) &&
                          resource.data.status == 'returned' &&
                          isValidSubmission(request.resource.data) &&
                          request.resource.data.uid == resource.data.uid &&
                          request.resource.data.milestoneId == resource.data.milestoneId &&
                          request.resource.data.status == 'submitted') ||
                         (canVerify(resource.data.milestoneId) &&
                          resource.data.status == 'submitted' &&
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'verifierUid', 'verifierName', 'returnReason', 'decidedAt']) &&
                          request.resource.data.status in ['verified', 'returned'] &&
                          request.resource.data.verifierUid == request.auth.uid &&
                          (request.resource.data.status == 'verified' ||
                           validString(request.resource.data.returnReason, 1, 300)));

        allow delete: if false;
      }

      // ---------------- Build log ----------------

      match /logs/{logId} {
        allow read: if isCohortMember(cohortId) || isMentor();

        allow create: if isCohortMember(cohortId) &&
                         consentAllows(request.auth.uid) &&
                         hasOnlyAllowedFields(['uid', 'name', 'text', 'day', 'createdAt']) &&
                         hasRequiredFields(['uid', 'name', 'text', 'day', 'createdAt']) &&
                         request.resource.data.uid == request.auth.uid &&
                         validString(request.resource.data.name, 1, 80) &&
                         validString(request.resource.data.text, 1, 300) &&
                         validString(request.resource.data.day, 10, 10);

        allow update: if false;
        allow delete: if isOwner(resource.data.uid);
      }
    }

    // ===============================================================
    // Workshops — mentors author the catalog from the admin panel;
    // every signed-in operator reads it.
    // ===============================================================

    function isValidWorkshop(data) {
      return hasOnlyAllowedFields(['title', 'mentorName', 'description', 'kind',
               'startsAt', 'durationMins', 'meetLink', 'open', 'levelGate',
               'milestoneId', 'recordingUrl']) &&
             hasRequiredFields(['title', 'mentorName', 'kind', 'startsAt',
               'durationMins', 'open', 'levelGate', 'milestoneId']) &&
             validString(data.title, 1, 120) &&
             validString(data.mentorName, 1, 80) &&
             (!('description' in data) || validString(data.description, 0, 1000)) &&
             data.kind in ['workshop', 'office_hours'] &&
             data.startsAt is timestamp &&
             data.durationMins is number && data.durationMins > 0 && data.durationMins <= 600 &&
             (!('meetLink' in data) || validString(data.meetLink, 0, 500)) &&
             data.open is bool &&
             data.levelGate is number && data.levelGate >= 0 && data.levelGate <= 5 &&
             data.milestoneId is number && data.milestoneId >= 0 && data.milestoneId <= 7 &&
             (!('recordingUrl' in data) || validString(data.recordingUrl, 0, 500));
    }

    match /workshops/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isMentor() && isValidWorkshop(request.resource.data);
      allow delete: if isMentor();
    }

    // ===============================================================
    // Consent tokens — server-only. Minted, read, and consumed exclusively
    // by the Admin SDK (Route Handlers under app/api/consent/**), which
    // bypasses these rules. No client may ever read or write them: the token
    // hash must never be exposed, and grants must stay server-authoritative.
    // ===============================================================

    match /consentTokens/{tokenHash} {
      allow read, write: if false;
    }

    // ===============================================================
    // Mentor invites — server-only, same posture as consentTokens.
    // Minted by staff (scripts/mentor-invite.js, CLI OAuth) and consumed
    // exclusively by the Admin SDK (/api/mentor/redeem). The doc id is the
    // SHA-256 hash of the invite code, so even a hypothetical read could
    // never leak a usable code — but no client may read or write anyway:
    // becoming a mentor must stay server-authoritative.
    // ===============================================================

    match /mentorInvites/{codeHash} {
      allow read, write: if false;
    }
  }
}
